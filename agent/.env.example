# ── Agent identity ────────────────────────────────────────
AGENT_NAME=JatinMomentumBot
AGENT_EMAIL=darthmelonder@gmail.com
AGENT_PASSWORD=choose_a_strong_password

# ── Platform ──────────────────────────────────────────────
BASE_URL=https://ai4trade.ai/api

# ── Notifications ─────────────────────────────────────────
# Install the ntfy app (iOS/Android), subscribe to this topic
NTFY_TOPIC=jatin-trading-alerts

# Optional Discord webhook URL (leave blank to disable)
DISCORD_WEBHOOK_URL=

# ── Strategy tuning ───────────────────────────────────────
STOP_LOSS_PCT=8.0
MAX_POSITIONS=3
POSITION_SIZE_PCT=20.0
MAX_POSITION_AGE_DAYS=90

# ── Timing ────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=3600
HEARTBEAT_INTERVAL_SECONDS=60

# ── Operation mode ────────────────────────────────────────
# true = log everything, make zero write API calls (safe to test)
DRY_RUN=true

# ── Active strategies (comma-separated) ───────────────────
ACTIVE_STRATEGIES=momentum_macro
