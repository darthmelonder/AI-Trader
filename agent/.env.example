# ── Agent identity ────────────────────────────────────────
AGENT_NAME=JatinMomentumBot
AGENT_EMAIL=darthmelonder@gmail.com
AGENT_PASSWORD=choose_a_strong_password

# ── Platform ──────────────────────────────────────────────
BASE_URL=https://ai4trade.ai/api

# ── Notifications ─────────────────────────────────────────
# Install the ntfy app (iOS/Android), subscribe to this topic
NTFY_TOPIC=jatin-trading-alerts

# Optional Discord webhook URL (leave blank to disable)
DISCORD_WEBHOOK_URL=

# ── Strategy tuning ───────────────────────────────────────
STOP_LOSS_PCT=8.0
MAX_POSITIONS=3
POSITION_SIZE_PCT=20.0
MAX_POSITION_AGE_DAYS=90

# ── Timing ────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=3600
HEARTBEAT_INTERVAL_SECONDS=60

# ── Operation mode ────────────────────────────────────────
# true = log everything, make zero write API calls (safe to test)
DRY_RUN=true

# ── Active strategies (comma-separated) ───────────────────
# Enable one or both strategies:
#   momentum_macro  — intraday momentum, pure rule-based gates, no external AI
#   llm_swing       — LLM-guided swing trade, 1-4 week holds, needs ANTHROPIC_API_KEY
ACTIVE_STRATEGIES=momentum_macro

# ── External data API keys (required for llm_swing) ───────
ALPHA_VANTAGE_API_KEY=           # used by llm_swing for RSI/MACD; free at alphavantage.co
GEMINI_API_KEY=                  # Gemini API key; free tier at aistudio.google.com
FRED_API_KEY=                    # free at https://fredaccount.stlouisfed.org/apikeys

# ── Strategy 2 (llm_swing) tuning ─────────────────────────
S2_MIN_LLM_CONFIDENCE=0.70       # minimum Claude confidence score to open a position
S2_MAX_POSITIONS=3
S2_POSITION_SIZE_PCT=15.0        # % of cash per trade (smaller than S1 — longer holds)
S2_MAX_HOLD_DAYS=30              # force-exit after this many days
S2_LLM_CACHE_TTL_HOURS=24       # re-use Claude decision for this many hours
S2_EARNINGS_BLACKOUT_DAYS=5      # skip entry if earnings within this window
S2_STOP_LOSS_PCT=9.0
S2_TARGET_RETURN_PCT=12.0
